{
  "name": "smart-class-lookup",
  "displayName": "Smart Class Search",
  "description": "Paste classes copied from DevTools and instantly find the matching component in your workspace. Built for Tailwind — supports cn(), clsx(), classnames(), template literals, arrays, ternaries, and conditional classNames.",
  "version": "0.3.0",
  "publisher": "nazmul-hossain-adnan",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Armstain/smart-class-lookup"
  },
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "css",
    "tailwind",
    "tailwindcss",
    "uno",
    "search",
    "clsx",
    "cn"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "smart-class-lookup-sidebar",
          "title": "Smart Class Search",
          "icon": "resources/search.svg"
        }
      ]
    },
    "views": {
      "smart-class-lookup-sidebar": [
        {
          "type": "webview",
          "id": "smartClassLookup.sidebarView",
          "name": "Class Search"
        }
      ]
    },
    "commands": [
      {
        "command": "smartClassLookup.search",
        "title": "Smart Class Search",
        "category": "Smart Class Search"
      },
      {
        "command": "smartClassLookup.rebuildIndex",
        "title": "Smart Class Search: Rebuild Index",
        "category": "Smart Class Search"
      },
      {
        "command": "smartClassLookup.findDuplicates",
        "title": "Smart Class Search: Find Duplicate Components",
        "category": "Smart Class Search"
      },
      {
        "command": "smartClassLookup.replace",
        "title": "Smart Class Search: Replace Class...",
        "category": "Smart Class Search"
      }
    ],
    "configuration": {
      "title": "Smart Class Search",
      "properties": {
        "smartClassLookup.include": {
          "type": "string",
          "default": "**/*.{ts,tsx,js,jsx}",
          "description": "Glob pattern (relative to each workspace folder) for files to index."
        },
        "smartClassLookup.exclude": {
          "type": "string",
          "default": "**/{node_modules,.next,dist,build,coverage,.git,out}/**",
          "description": "Glob pattern for files/folders to exclude from indexing."
        },
        "smartClassLookup.maxResults": {
          "type": "number",
          "default": 25,
          "description": "Maximum number of ranked results to show in the Quick Pick."
        },
        "smartClassLookup.minScore": {
          "type": "number",
          "default": 0.3,
          "description": "Minimum match score (0-1) a file must reach to be shown in results."
        },
        "smartClassLookup.enablePreview": {
          "type": "boolean",
          "default": true,
          "description": "Enable live preview of the file when navigating results (Quick Pick and Sidebar)."
        },
        "smartClassLookup.duplicateMinClasses": {
          "type": "number",
          "default": 3,
          "description": "Minimum number of classes an element must share with another element (in a different file) to be reported by 'Find Duplicate Components'."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "test": "npm run compile && node test/smoke.js"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@babel/parser": "^7.24.6",
    "@babel/traverse": "^7.24.6"
  }
}
